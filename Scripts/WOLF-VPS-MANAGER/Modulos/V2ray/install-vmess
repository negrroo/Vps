#!/bin/bash

#sudo tee /usr/local/sbin/install-vmess > /dev/null <<'SCRIPT'

echo "Checking environment..."

# must run as root
if [ "$EUID" -ne 0 ]; then
  echo "Run as root"
  exit
fi

############################################
# INSTALL Domain if no
############################################
if [[ ! -f /etc/.domain ]]; then
echo -ne "\033[1;36m◇ Do you want to add a domain name? [Y/N]: \033[0m"
read add_domain
echo ""

echo -e "\033[1;32m>>> Make sure your domain is pointed to this VPS IP <<<\033[0m"

SERVER_IP=$(curl -s ipv4.icanhazip.com)

domain_name=""

if [[ "$add_domain" == [Yy]* ]]; then
    attempts=0

    while [[ $attempts -lt 3 ]]; do
        echo -ne "\033[1;36m◇ Enter domain (example.com): \033[0m"
        read domain_input
        echo ""

        if [[ $domain_input =~ ^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$ ]]; then

            DOMAIN_IP=$(getent hosts "$domain_input" | awk '{print $1}' | head -n1)

            if [[ "$DOMAIN_IP" == "$SERVER_IP" ]]; then

                domain_name="$domain_input"
                echo "$domain_name" > /etc/.domain

                echo -e "\033[1;32mDomain verified and saved: $domain_name\033[0m"
                break

            else
                echo -e "\033[1;31mDomain is NOT pointing to this server!\033[0m"
                echo -e "Expected: $SERVER_IP"
                echo -e "Got     : $DOMAIN_IP"
            fi

        else
            echo -e "\033[1;31mInvalid domain format\033[0m"
        fi

        ((attempts++))
    done

    [[ -z "$domain_name" ]] && echo "Skipping domain setup."

else
    echo "No domain added."
fi
fi

############################################
# DETECT MODE
############################################

PORT443=$(ss -tulpn | grep ':443 ')
PORT8443=$(ss -tulpn | grep ':8443 ')

if echo "$PORT443" | grep -q stunnel; then
    MODE="STUNNEL"

elif echo "$PORT443" | grep -q haproxy && echo "$PORT8443" | grep -q nginx; then
    MODE="FALCON"

else
    echo "ERROR: Unsupported environment"
    echo "$PORT443"
    exit
fi

echo "Detected MODE: $MODE"

############################################
# ===============================
# CASE 1 → YOUR ORIGINAL SCRIPT
# ===============================
############################################

if [[ "$MODE" == "STUNNEL" ]]; then

# ======= YOUR SCRIPT (UNCHANGED) =======

# check stunnel installed
if ! command -v stunnel4 >/dev/null 2>&1; then
  echo "ERROR: stunnel not installed"
  exit
fi

# check config exists
if [ ! -f /etc/stunnel/stunnel.conf ]; then
  echo "ERROR: stunnel config missing"
  exit
fi

# check certificate exists
if [ ! -f /etc/stunnel/stunnel.pem ]; then
  echo "ERROR: stunnel certificate missing"
  exit
fi

# detect stunnel port
if ss -tulpn | grep ':443 ' | grep -q stunnel; then

echo "Detected stunnel on 443"

MOVE_STUNNEL=true

elif ss -tulpn | grep ':444 ' | grep -q stunnel; then

echo "Detected stunnel already on 444"

MOVE_STUNNEL=false

else

echo "ERROR: stunnel not running on 443 or 444"
exit

fi


echo "Installing packages..."

apt update -y
apt install curl socat haproxy -y


echo "Installing Xray..."

bash <(curl -Ls https://raw.githubusercontent.com/XTLS/Xray-install/main/install-release.sh)


mkdir -p /usr/local/etc/xray


echo "Creating Xray config..."

cat > /usr/local/etc/xray/config.json <<EOF
{
"log":{
"loglevel":"warning"
},

"inbounds":[
{
"port":8443,
"protocol":"vmess",

"settings":{
"clients":[]
},

"streamSettings":{
"network":"ws",

"security":"tls",

"tlsSettings":{
"certificates":[
{
"certificateFile":"/etc/stunnel/stunnel.pem",
"keyFile":"/etc/stunnel/stunnel.pem"
}
]
},

"wsSettings":{
"path":"/vmess"
}
}
}
],

"outbounds":[
{
"protocol":"freedom"
}
]
}
EOF


systemctl enable xray
systemctl restart xray


if [ "$MOVE_STUNNEL" = true ]; then

echo "Moving stunnel 443 → 444"

killall stunnel4
sleep 2
sed -i 's/accept = 443/accept = 444/g' /etc/stunnel/stunnel.conf
systemctl start stunnel4

# Restart again
service stunnel4 restart
service ssh restart
/etc/init.d/stunnel4 restart
fi

DOMAIN=$(cat /etc/.domain)
echo "Detected domain: $DOMAIN"

echo "Configuring HAProxy..."

if ! grep -q "shared443" /etc/haproxy/haproxy.cfg; then

cat >> /etc/haproxy/haproxy.cfg <<EOF

frontend shared443
    bind *:443
    mode tcp

    tcp-request inspect-delay 2s
    tcp-request content accept if { req_ssl_hello_type 1 }

    # SSL SSH SNI
    # use_backend ssh if { req.ssl_sni -i m.youtube.com }

    # VMESS SNI
    use_backend vmess if { req.ssl_sni -i $DOMAIN }
    # use_backend vmess if { req.ssl_sni -i youtube.com }

    default_backend ssh


backend ssh
    mode tcp
    server ssh 127.0.0.1:444


backend vmess
    mode tcp
    server vmess 127.0.0.1:8443

EOF

fi

systemctl enable haproxy
systemctl restart haproxy

############################################
# ===============================
# CASE 2 → FALCON MODE (NGINX)
# ===============================
############################################

elif [[ "$MODE" == "FALCON" ]]; then

echo "Using FALCON MODE (nginx routing)"

apt update -y
apt install -y curl

bash <(curl -Ls https://raw.githubusercontent.com/XTLS/Xray-install/main/install-release.sh)

mkdir -p /usr/local/etc/xray

XRAY_PORT=10001

############################################
# XRAY CONFIG (NO TLS)
############################################
echo "Creating Xray config..."

cat > /usr/local/etc/xray/config.json <<EOF
{
"log":{
"loglevel":"warning"
},

"inbounds":[
{
"port":$XRAY_PORT,
"protocol":"vmess",

"settings":{
"clients":[]
},

"streamSettings":{
"network":"ws",

"security":"none",

"wsSettings":{
"path":"/vmess"
}
}
}
],

"outbounds":[
{
"protocol":"freedom"
}
]
}
EOF


systemctl enable xray
systemctl restart xray

############################################
# NGINX ROUTING (SAFE INJECT)
############################################

NGINX_CONF="/etc/nginx/sites-enabled/default"
[ ! -f "$NGINX_CONF" ] && NGINX_CONF="/etc/nginx/nginx.conf"

if ! grep -q "/vmess" "$NGINX_CONF"; then

sed -i "/server {/a \\
    location /vmess {\\
        proxy_pass http://127.0.0.1:$XRAY_PORT;\\
        proxy_http_version 1.1;\\
        proxy_set_header Upgrade \$http_upgrade;\\
        proxy_set_header Connection \"upgrade\";\\
        proxy_set_header Host \$host;\\
    }" "$NGINX_CONF"

fi

systemctl restart nginx

fi

############################################
# SAVE INSTALLED VERSION
############################################

REPO="https://raw.githubusercontent.com/negrroo/Vps/main/Scripts/WOLF-VPS-MANAGER/Modulos/V2ray"

Latest=$(curl -fsSL $REPO/version 2>/dev/null)

if [[ -n "$Latest" ]]
then
echo "$Latest" > /etc/vmess-version
else
echo "1.0" > /etc/vmess-version
fi


echo ""
echo "VMESS installed successfully"
echo ""
echo "Mode: $MODE"
echo "Port : 443"
echo "Path : /vmess"
echo ""

#SCRIPT

#chmod +x /usr/local/sbin/install-vmess
#bash /usr/local/sbin/install-vmess
