#!/bin/bash

#sudo tee /usr/local/sbin/install-vmess > /dev/null <<'SCRIPT'

echo "Checking environment..."

# must run as root
if [ "$EUID" -ne 0 ]; then
  echo "Run as root"
  exit
fi

############################################
# DETECT PORT 443 OWNER
############################################

echo "Checking port 443..."

PORT_443=$(ss -tulpn | grep ':443 ')

if echo "$PORT_443" | grep -q haproxy; then

    echo "Detected HAProxy on 443"
    MODE="HAPROXY"

elif echo "$PORT_443" | grep -q stunnel; then

    echo "Detected stunnel on 443"
    MODE="STUNNEL"

elif [[ -z "$PORT_443" ]]; then

    echo "Port 443 is free"
    MODE="FREE"

else

    echo "ERROR: Unknown service using 443"
    echo "$PORT_443"
    exit 1

fi

############################################
# INSTALL PACKAGES
############################################

echo "Installing packages..."

apt update -y
apt install curl socat haproxy -y

############################################
# INSTALL XRAY
############################################

echo "Installing Xray..."
bash <(curl -Ls https://raw.githubusercontent.com/XTLS/Xray-install/main/install-release.sh)

mkdir -p /usr/local/etc/xray

############################################
# CREATE XRAY CONFIG (AUTO MODE)
############################################

echo "Creating Xray config..."

if [[ "$MODE" == "HAPROXY" ]]; then

# NO TLS (handled by HAProxy)

cat > /usr/local/etc/xray/config.json <<EOF
{
"log":{"loglevel":"warning"},
"inbounds":[
{
"port":8443,
"protocol":"vmess",
"settings":{"clients":[]},
"streamSettings":{
"network":"ws",
"security":"none",
"wsSettings":{"path":"/vmess"}
}
}
],
"outbounds":[{"protocol":"freedom"}]
}
EOF

else

# STUNNEL MODE (TLS inside xray)

cat > /usr/local/etc/xray/config.json <<EOF
{
"log":{"loglevel":"warning"},
"inbounds":[
{
"port":8443,
"protocol":"vmess",
"settings":{"clients":[]},
"streamSettings":{
"network":"ws",
"security":"tls",
"tlsSettings":{
"certificates":[
{
"certificateFile":"/etc/stunnel/stunnel.pem",
"keyFile":"/etc/stunnel/stunnel.pem"
}
]
},
"wsSettings":{"path":"/vmess"}
}
}
],
"outbounds":[{"protocol":"freedom"}]
}
EOF

fi

systemctl enable xray
systemctl restart xray

############################################
# STUNNEL HANDLING (ONLY IF USED)
############################################

if [[ "$MODE" == "STUNNEL" ]]; then

echo "Moving stunnel 443 → 444"

killall stunnel4 2>/dev/null
sleep 2

sed -i 's/accept = 443/accept = 444/g' /etc/stunnel/stunnel.conf

systemctl restart stunnel4
service ssh restart

fi

############################################
# HAPROXY INTEGRATION
############################################

DOMAIN=$(cat /etc/.domain 2>/dev/null)
echo "Detected domain: $DOMAIN"

if [[ "$MODE" == "HAPROXY" ]]; then

echo "Integrating with existing HAProxy..."

# only add backend if missing
if ! grep -q "backend vmess" /etc/haproxy/haproxy.cfg; then

cat >> /etc/haproxy/haproxy.cfg <<EOF

# ===== VMESS BACKEND =====
backend vmess
    mode tcp
    server vmess 127.0.0.1:8443

EOF

fi

systemctl restart haproxy

elif [[ "$MODE" == "FREE" ]]; then

echo "Setting up new HAProxy..."

cat >> /etc/haproxy/haproxy.cfg <<EOF

frontend shared443
    bind *:443
    mode tcp
    tcp-request inspect-delay 2s
    tcp-request content accept if { req_ssl_hello_type 1 }

    use_backend vmess if { req.ssl_sni -i $DOMAIN }
    default_backend ssh

backend ssh
    mode tcp
    server ssh 127.0.0.1:22

backend vmess
    mode tcp
    server vmess 127.0.0.1:8443

EOF

systemctl enable haproxy
systemctl restart haproxy

fi

############################################
# SAVE VERSION
############################################

REPO="https://raw.githubusercontent.com/negrroo/Vps/main/Scripts/WOLF-VPS-MANAGER/Modulos/V2ray"
Latest=$(curl -fsSL $REPO/version 2>/dev/null)

[[ -n "$Latest" ]] && echo "$Latest" > /etc/vmess-version || echo "1.0" > /etc/vmess-version

############################################
# DONE
############################################

echo ""
echo "VMESS installed successfully"
echo ""
echo "Port : 443"
echo "Path : /vmess"
echo ""

if [[ "$MODE" == "HAPROXY" ]]; then
echo "Using existing HAProxy (SNI routing)"
else
echo "Using local TLS / stunnel mode"
fi

echo ""

#SCRIPT

#chmod +x /usr/local/sbin/install-vmess
#bash /usr/local/sbin/install-vmess
