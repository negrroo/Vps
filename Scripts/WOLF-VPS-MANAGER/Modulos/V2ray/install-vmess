#!/bin/bash

#sudo tee /usr/local/sbin/install-vmess > /dev/null <<'SCRIPT'

echo "Checking environment..."

# root check
[ "$EUID" -ne 0 ] && echo "Run as root" && exit

############################################
# DETECT MODE (STUNNEL / HAPROXY)
############################################

MODE="unknown"

if ss -tulpn | grep -q ':443 ' | grep -q haproxy; then
    MODE="haproxy"
elif ss -tulpn | grep -q ':443 ' | grep -q stunnel; then
    MODE="stunnel"
fi

echo "Detected mode: $MODE"

############################################
# INSTALL BASE PACKAGES
############################################

apt update -y
apt install -y curl socat nginx

############################################
# INSTALL XRAY
############################################

bash <(curl -Ls https://raw.githubusercontent.com/XTLS/Xray-install/main/install-release.sh)

mkdir -p /usr/local/etc/xray

############################################
# PORT AUTO FIX (8443 conflict)
############################################

XRAY_PORT=8443

if ss -tulpn | grep -q ":8443 "; then
    XRAY_PORT=10001
fi

############################################
# CREATE XRAY CONFIG BASED ON MODE
############################################

if [[ "$MODE" == "stunnel" ]]; then

cat > /usr/local/etc/xray/config.json <<EOF2
{
"log":{"loglevel":"warning"},
"inbounds":[
{
"port":$XRAY_PORT,
"protocol":"vmess",
"settings":{"clients":[]},
"streamSettings":{
"network":"ws",
"security":"tls",
"tlsSettings":{
"certificates":[
{
"certificateFile":"/etc/stunnel/stunnel.pem",
"keyFile":"/etc/stunnel/stunnel.pem"
}
]
},
"wsSettings":{"path":"/vmess"}
}
}
],
"outbounds":[{"protocol":"freedom"}]
}
EOF2

else

# HAPROXY MODE → NO TLS

cat > /usr/local/etc/xray/config.json <<EOF2
{
"log":{"loglevel":"warning"},
"inbounds":[
{
"port":$XRAY_PORT,
"protocol":"vmess",
"settings":{"clients":[]},
"streamSettings":{
"network":"ws",
"security":"none",
"wsSettings":{"path":"/vmess"}
}
}
],
"outbounds":[{"protocol":"freedom"}]
}
EOF2

fi

############################################
# ENABLE XRAY
############################################

systemctl enable xray
systemctl restart xray

############################################
# HAPROXY MODE → CONFIGURE NGINX
############################################

if [[ "$MODE" == "haproxy" ]]; then

echo "Configuring nginx for VMESS..."

# find nginx TLS config
NGINX_CONF="/etc/nginx/sites-enabled/default"

if [ ! -f "$NGINX_CONF" ]; then
    NGINX_CONF="/etc/nginx/nginx.conf"
fi

# inject only if not exists
if ! grep -q "/vmess" "$NGINX_CONF"; then

sed -i "/server {/a \\
    location /vmess {\\
        proxy_pass http://127.0.0.1:$XRAY_PORT;\\
        proxy_http_version 1.1;\\
        proxy_set_header Upgrade \$http_upgrade;\\
        proxy_set_header Connection \"upgrade\";\\
        proxy_set_header Host \$host;\\
    }" "$NGINX_CONF"

fi

systemctl restart nginx

fi

############################################
# SAVE VERSION
############################################

REPO="https://raw.githubusercontent.com/negrroo/Vps/main/Scripts/WOLF-VPS-MANAGER/Modulos/V2ray"

Latest=$(curl -fsSL $REPO/version 2>/dev/null)

[[ -n "$Latest" ]] && echo "$Latest" > /etc/vmess-version || echo "1.0" > /etc/vmess-version

############################################
# DONE
############################################

echo ""
echo "======================================="
echo " VMESS INSTALLED SUCCESSFULLY"
echo "======================================="
echo ""
echo "Port  : 443"
echo "Path  : /vmess"
echo "Mode  : $MODE"
echo ""
echo "IMPORTANT:"
echo "Client must use:"
echo "TLS  : ON"
echo "Path : /vmess"
echo ""


#SCRIPT

#chmod +x /usr/local/sbin/install-vmess
#bash /usr/local/sbin/install-vmess
