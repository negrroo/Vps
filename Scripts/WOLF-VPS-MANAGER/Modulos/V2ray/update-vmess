#!/bin/bash

#cat > /usr/local/sbin/update-vmess <<'EOF'

############################################
# PATHS
############################################

BASE_DIR="/usr/local/sbin"

VERSION_FILE="/etc/vmess-version"

REPO="https://raw.githubusercontent.com/negrroo/Vps/main/Scripts/WOLF-VPS-MANAGER/Modulos/V2ray"

############################################
# FILES TO UPDATE
############################################

FILES=(
vmess-modules
install-vmess
)

############################################
# Fun bar
############################################
	fun_bar() {
		comando[0]="$1"
		comando[1]="$2"
		(
			[[ -e $HOME/fim ]] && rm $HOME/fim
			[[ ! -d /etc/VPSManager ]] && rm -rf /bin/menu
			${comando[0]} >/dev/null 2>&1
			${comando[1]} >/dev/null 2>&1
			touch $HOME/fim
		) >/dev/null 2>&1 &
		tput civis
		echo -ne "\033[1;33mPLEASE WAIT... \033[1;37m- \033[1;33m["
		while true; do
			for ((i = 0; i < 18; i++)); do
				echo -ne "\033[1;31m#"
				sleep 0.1s
			done
			[[ -e $HOME/fim ]] && rm $HOME/fim && break
			echo -e "\033[1;33m]"
			sleep 1s
			tput cuu1
			tput dl1
			echo -ne "\033[1;33mPLEASE WAIT... \033[1;37m- \033[1;33m["
		done
		echo -e "\033[1;33m]\033[1;37m -\033[1;32m DONE !\033[1;37m"
		tput cnorm
	}

############################################
# COLORS
############################################

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
NC='\033[0m'

############################################
# HEADER
############################################

clear

tput setaf 7;tput setab 4;tput bold
printf '%30s%s%-15s\n' "🔄 VMESS UPDATE 🔄"
tput sgr0

echo ""

############################################
# GET LOCAL VERSION
############################################

if [[ -f $VERSION_FILE ]]
then
LOCAL_VERSION=$(cat $VERSION_FILE)
else
LOCAL_VERSION="unknown"
fi

############################################
# GET REMOTE VERSION
############################################

REMOTE_VERSION=$(curl -s $REPO/version 2>/dev/null)

############################################
# SHOW VERSION INFO
############################################

echo -e "${CYAN}Installed version:${NC} $LOCAL_VERSION"
echo -e "${CYAN}Latest version:${NC} $REMOTE_VERSION"

echo ""

############################################
# CHECK UPDATE
############################################

if [[ "$LOCAL_VERSION" == "$REMOTE_VERSION" && "$REMOTE_VERSION" != "" ]]
then

echo -e "${GREEN}System already updated ✔${NC}"

echo ""
read -p $'\033[1;31mENTER to return MENU\033[0m'

exit 0

fi

############################################
# DOWNLOAD FILES
############################################

echo -e "${YELLOW}Updating modules...${NC}"
echo ""

for f in "${FILES[@]}"
do

echo -e "${CYAN}Downloading:${NC} $f"

curl -fsSL -o $BASE_DIR/$f $REPO/$f

chmod +x $BASE_DIR/$f

done

############################################
# INSTALLATION
############################################

                wget -q -O /bin/conexao https://raw.githubusercontent.com/negrroo/Vps/main/Scripts/WOLF-VPS-MANAGER/Modulos/V2ray/vconexao && chmod +x /bin/conexao
                wget -q -O /bin/menu https://raw.githubusercontent.com/negrroo/Vps/main/Scripts/WOLF-VPS-MANAGER/Modulos/V2ray/vmenu && chmod +x /bin/menu

                echo ""
                echo -e "\033[1;32mUPDATING USER MODULES...\033[0m"
                echo ""
                fun_bar 'bash /usr/local/sbin/vmess-modules'

############################################
# SAVE VERSION
############################################

if [[ "$REMOTE_VERSION" != "" ]]
then
echo "$REMOTE_VERSION" > $VERSION_FILE
fi

############################################
# SAFE SERVICE RESTART
############################################

echo ""
echo -e "${YELLOW}Restarting services...${NC}"

systemctl restart xray 2>/dev/null
systemctl restart haproxy 2>/dev/null

############################################
# DONE
############################################

echo ""
echo -e "${GREEN}Update completed ✔${NC}"

echo -e "${CYAN}Current version:${NC} ${REMOTE_VERSION:-unknown}"

echo ""

#EOF

#chmod +x /usr/local/sbin/update-vmess
