########################
# DELETE USER
########################

cat > /usr/local/sbin/del-vmess <<'EOF'
#!/bin/bash

CONFIG="/usr/local/etc/xray/config.json"

read -p "Username : " user

sed -i "/\"email\": \"$user\"/,+2 d" $CONFIG

sed -i "/^$user /d" /etc/vmess-exp
sed -i "/^$user /d" /etc/vmess-iplimit

systemctl restart xray

echo "User deleted"
EOF


########################
# LIST USERS
########################

cat > /usr/local/sbin/list-vmess <<'EOF'
#!/bin/bash

printf "%-20s %-12s %-8s\n" USER EXPIRE STATUS
echo "-------------------------------------------"

while read u d s
do
printf "%-20s %-12s %-8s\n" $u $d $s
done < /etc/vmess-exp
EOF


########################
# RENEW USER
########################

cat > /usr/local/sbin/renew-vmess <<'EOF'
#!/bin/bash

read -p "Username : " user
read -p "Extend days : " days

newdate=$(date -d "$days days" +"%Y-%m-%d")

sed -i "s/^$user .*/$user $newdate active/" /etc/vmess-exp

echo "Expiry updated to $newdate"
EOF


########################
# LOCK USER
########################

cat > /usr/local/sbin/lock-vmess <<'EOF'
#!/bin/bash

CONFIG="/usr/local/etc/xray/config.json"

read -p "Username : " user

sed -i "/\"email\": \"$user\"/,+2 d" $CONFIG

sed -i "s/$user .* active/$user $(grep $user /etc/vmess-exp | awk '{print $2}') locked/" /etc/vmess-exp

systemctl restart xray

echo "User locked"
EOF


########################
# UNLOCK USER
########################

cat > /usr/local/sbin/unlock-vmess <<'EOF'
#!/bin/bash

CONFIG="/usr/local/etc/xray/config.json"

read -p "Username : " user

uuid=$(cat /proc/sys/kernel/random/uuid)

sed -i '/"clients": \[/a\    {\n      "id": "'"$uuid"'",\n      "alterId": 0,\n      "email": "'"$user"'"\n    },' $CONFIG

sed -i "s/$user .* locked/$user $(grep $user /etc/vmess-exp | awk '{print $2}') active/" /etc/vmess-exp

systemctl restart xray

echo "User unlocked"
EOF


