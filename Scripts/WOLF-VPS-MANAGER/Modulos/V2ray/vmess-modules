cat > /usr/local/sbin/lock-vmess <<'EOF'
#!/bin/bash

CONFIG="/usr/local/etc/xray/config.json"
EXPDB="/etc/vmess-exp"

lock_user(){

user="$1"

uuid=$(grep -A1 "\"email\": \"$user\"" $CONFIG \
| grep '"id"' \
| head -1 \
| cut -d'"' -f4)

[[ -z "$uuid" ]] && return

first=${uuid:0:1}
rest=${uuid:1}

next=$(echo "$first" | tr 0-8a-yA-Y 1-9b-zB-Z)

[[ "$first" = "9" ]] && next=0
[[ "$first" = "z" ]] && next=a
[[ "$first" = "Z" ]] && next=A

newuuid="${next}${rest}"

sed -i "s/$uuid/$newuuid/g" $CONFIG

oldexp=$(grep "^$user " $EXPDB | awk '{print $2}')

sed -i "s/^$user $oldexp active/$user $oldexp locked/" $EXPDB

echo "$user locked"

}

########################################
# CLI MODE (used by expire script)
########################################

if [[ ! -z "$1" ]]; then
lock_user "$1"
systemctl restart xray 2>/dev/null
exit
fi

########################################
# INTERACTIVE MODE
########################################

clear
tput setaf 7;tput setab 4;tput bold
printf '%32s%s%-13s\n' "  🔒 Lock VMESS User 🔒 "
tput sgr0

echo ""
echo -e "\033[1;33m◇ LIST OF ACTIVE USERS:\033[0m"
echo ""

i=0

while read user exp status
do

[[ "$status" != "active" ]] && continue

i=$((i+1))

printf "\033[1;31m[%02d]\033[1;32m %s \033[1;37m(exp: %s)\033[0m\n" $i "$user" "$exp"

users[$i]=$user

done < $EXPDB

echo ""

read -p $'\033[1;32m◇ Enter user number:\033[0m ' num

user="${users[$num]}"

[[ -z "$user" ]] && exit

lock_user "$user"

systemctl restart xray 2>/dev/null

echo ""
echo -e "\033[1;32mUser locked successfully\033[0m"
echo ""

EOF

chmod +x /usr/local/sbin/lock-vmess

