tput setaf 7;tput setab 4;tput bold
printf '%30s%s%-15s\n' "📄 VMESS CONFIG 📄"
tput sgr0

echo ""

############################################
# LOAD USERS
############################################

mapfile -t users < <(cut -d' ' -f1 $VMESS_DB 2>/dev/null)

if [[ ${#users[@]} -eq 0 ]]
then
echo -e "\033[1;31mNo users found\033[0m"
echo ""
read -p $'\033[1;31m◇ ENTER to return to MENU\033[0m'
exit
fi

############################################
# USER LIST
############################################

echo -e "\033[1;33m◇ SELECT USER:\033[0m"
echo ""

i=1

for u in "${users[@]}"
do

printf "\033[1;31m[%02d]\033[1;32m %s\n" "$i" "$u"

((i++))

done

echo ""

read -p $'\033[1;36mSelect number: \033[0m' num

user="${users[$((num-1))]}"

[[ -z "$user" ]] && exit

############################################
