########################

cat > /usr/local/sbin/usage-vmess <<'EOF'
#!/bin/bash

grep email /var/log/xray/access.log | \
awk '{print $NF,$5}' | \
sed 's/email://g' | \
awk '

{
user=$1
bytes=$2
usage[user]+=bytes
}

END {

for (u in usage)

printf "%-15s %.2f MB\n", u, usage[u]/1024/1024

}'
EOF


