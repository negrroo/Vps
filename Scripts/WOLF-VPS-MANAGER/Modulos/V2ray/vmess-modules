	echo -e "\n${cor1}Number of concurrent connections must be greater than zero!${scor}\n"
	exit 1
}


uuid=$(cat /proc/sys/kernel/random/uuid)
expdate=$(date -d "$exp days" +"%Y-%m-%d")

echo "$user $expdate active" >> /etc/vmess-exp
