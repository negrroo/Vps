########################
# IP LIMIT CHECKER
########################

cat > /usr/local/sbin/check-vmess-ip <<'EOF'
#!/bin/bash

LOG="/var/log/xray/access.log"

while read user limit
do

ipcount=$(grep "$user" $LOG | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)

if [ "$ipcount" -gt "$limit" ]; then

sed -i "/\"email\": \"$user\"/,+2 d" /usr/local/etc/xray/config.json

sed -i "s/$user .* active/$user $(grep $user /etc/vmess-exp | awk '{print $2}') locked/" /etc/vmess-exp

fi

done < /etc/vmess-iplimit

systemctl restart xray
EOF


########################
# EXPIRY LOCK
########################

cat > /usr/local/sbin/check-vmess-exp <<'EOF'
#!/bin/bash

today=$(date +"%Y-%m-%d")

while read user exp status
do

if [[ "$today" > "$exp" ]] && [[ "$status" = "active" ]]; then

sed -i "/\"email\": \"$user\"/,+2 d" /usr/local/etc/xray/config.json

sed -i "s/$user $exp active/$user $exp locked/" /etc/vmess-exp

fi

done < /etc/vmess-exp

systemctl restart xray
EOF


